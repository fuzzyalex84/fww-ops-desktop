{
  "name": "fww-ops-desktop",
  "version": "1.1.1",
  "description": "Fuzzywumpets Ops — desktop shell with auto-update + embedded app views",
  "author": "Fuzzywumpets",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "icons": "powershell -ExecutionPolicy Bypass -File tools/make-icons.ps1 && node tools/make-ico.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.fuzzywumpets.fwwops",
    "productName": "FWW Ops",
    "copyright": "Copyright © 2026 Fuzzywumpets",
    "icon": "assets/icon.png",
    "publish": {
      "provider": "github",
      "owner": "fuzzyalex84",
      "repo": "fww-ops-desktop"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Fuzzywumpets",
      "artifactName": "FWW-Ops-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FWW Ops",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ]
  }
}
